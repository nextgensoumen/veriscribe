# Application
APP_NAME="VeriScribe — Academic Intelligence Engine"
APP_PORT=8000
APP_HOST="127.0.0.1"

# Upload Limits
MAX_UPLOAD_SIZE_MB=50

# Model Configuration
# Model to use from HuggingFace
MODEL_NAME="sshleifer/distilbart-cnn-12-6"

# Chunking Configuration
# Max tokens per chunk to fit in model's input limit (1024 for distilbart)
CHUNK_SIZE_TOKENS=800
# Number of overlap tokens between chunks to preserve context
CHUNK_OVERLAP_TOKENS=100
